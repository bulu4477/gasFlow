    "contracts/Counter.sol": {
      "content": "// SPDX-License-Identifier: MIT\r\n\r\npragma solidity ^0.8.28;\r\n\r\ncontract Counter {\r\n    uint256 public x;\r\n\r\n    function inc1() public {\r\n        x++;\r\n    }\r\n\r\n    function increase(uint256 y) public {\r\n        x = x + y;\r\n    }\r\n}"
    }
